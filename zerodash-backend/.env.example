PORT=8788
MONGODB_URI=mongodb+srv://USER:PASS@cluster.example.mongodb.net/zerodash?retryWrites=true&w=majority

# Privy — required for POST /player/profile (JWT browser bootstrap from Kult / deep links)
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Optional — Privy Wallet API embedded flows
# PRIVY_WALLET_AUTHORIZATION_PRIVATE_KEY=

# 0G DA — same gateway pattern as Zero Pool / Highway Hustle
ZEROG_DA_ENABLED=true
ZEROG_DA_GATEWAY_URL=https://da.warzonewarriors.xyz
ZEROG_DA_API_TOKEN=

# Legacy alias supported in code:
# ZEROG_DA_API_KEY=

# 0G Compute — OpenAI-compatible inference (Mike chat + optional extras)
ZERO_G_API_KEY=
ZEROG_API_KEY=
ZERO_G_CHAT_MODEL=zai-org/GLM-5-FP8
ZERO_G_CHAT_BASE=https://compute-network-1.integratenetwork.work/v1/proxy

# NFT gasless relay (optional — omit to disable mint relay; proof endpoint still works)
NFT_CONTRACT_ADDRESS=0xbfe7aAfEB3145962943412413d69582630C5830D
NFT_RELAYER_PRIVATE_KEY=
OG_RPC_URL=https://evmrpc.0g.ai
NFT_MINT_MESSAGE_PREFIX=Mint Zero Dash Pass NFT to
# Non-whitelisted paid mint price in wei (0 on test / free mint)
NFT_MINT_VALUE_WEI=0

# Open whitelist UX: returns empty Merkle proof (contract must accept it when allowed)
NFT_OPEN_WHITELIST=true

# ── 0G EVM — optional on-chain session log (PB only, min score gate below) ──
# Deploy a contract with: recordSession(address player, uint256 highScore, uint256 coins, uint256 ts)
ZDASH_SESSION_CONTRACT_ADDRESS=
ZDASH_OPERATOR_PRIVATE_KEY=
ZDASH_CHAIN_RPC_URL=https://evmrpc.0g.ai
# Only fire when a new personal best posts (set false to disable entirely)
ZDASH_CHAIN_ON_PB=true
ZDASH_CHAIN_MIN_HIGHSCORE=50000

# ── Anti-cheat (heuristics + 0G Compute JSON verdict) ──
ZD_ANTICHEAT_ENABLED=true
ZD_ANTICHEAT_SUSPICIOUS_SCORE_DELTA=400000
ZD_ANTICHEAT_SUSPICIOUS_COINS_DELTA=5000000
ZD_ANTICHEAT_HARD_CAP_SCORE=9999999999
ZD_ANTICHEAT_TIMEOUT_MS=6000

# Leaderboard AI (GET /player/leaderboard/ai-comment)
# ZD_LEADERBOARD_AI_MODEL=zai-org/GLM-5-FP8
# ZD_LEADERBOARD_AI_RATE_LIMIT=45

# Rate limits
# ZEROG_DA_STATUS_RATE_LIMIT=60
